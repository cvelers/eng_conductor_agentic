# Logging
LOG_LEVEL=INFO

# LLM cognitive settings (model, temperature, max_tokens, reasoning_effort)
# → see cognitive_config.json

# API keys (secrets — never put these in cognitive_config.json)
ORCHESTRATOR_API_KEY=
SEARCH_API_KEY=

# Feature flags
AGENTIC_SEARCH_ENABLED=true
RECURSIVE_RETRIEVAL_ENABLED=false
EMBEDDINGS_ENABLED=false
MAX_RETRIEVAL_ITERS=3
TOP_K_CLAUSES=6

# Supabase (for auth & chat persistence — leave blank to run without auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
# Service role key (required for chat sync; get from Supabase Dashboard > Settings > API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
