# Logging
LOG_LEVEL=INFO

# Orchestrator model role (default: Gemini 3.1 Pro)
ORCHESTRATOR_PROVIDER=gemini
ORCHESTRATOR_MODEL=gemini-3.1-pro
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Gemini only: reasoning effort — low, medium, or high (blank = no default)
ORCHESTRATOR_REASONING_EFFORT=

# Tool writer model (for dev-mode tool generation — falls back to orchestrator if blank)
TOOL_WRITER_PROVIDER=gemini
TOOL_WRITER_MODEL=gemini-3.1-pro
TOOL_WRITER_API_KEY=
TOOL_WRITER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Gemini only: reasoning effort — low, medium, or high (blank = no default, or orchestrator value when falling back)
TOOL_WRITER_REASONING_EFFORT=

# Search model role (default: Kimi K2.5 via OpenRouter)
SEARCH_PROVIDER=openrouter
SEARCH_MODEL=moonshotai/kimi-k2.5
SEARCH_API_KEY=
SEARCH_BASE_URL=https://openrouter.ai/api/v1
SEARCH_DECOMPOSE_MAX_TOKENS=1200
# Gemini only: reasoning effort — low, medium, or high (blank = no default)
SEARCH_REASONING_EFFORT=

# Pipeline stage LLM parameters (override defaults per stage)
# Temperature, max tokens, and reasoning effort for each orchestration step.
# Defaults match current hardcoded values — no change needed unless tuning.
# reasoning_effort: low, medium, high (blank = provider default / not sent)
INTENT_TEMPERATURE=0
INTENT_MAX_TOKENS=256
INTENT_REASONING_EFFORT=low
DECOMPOSE_TEMPERATURE=0
DECOMPOSE_MAX_TOKENS=2048
DECOMPOSE_REASONING_EFFORT=low
RERANK_TEMPERATURE=0
RERANK_MAX_TOKENS=1200
RERANK_REASONING_EFFORT=
GAP_ANALYSIS_TEMPERATURE=0
GAP_ANALYSIS_MAX_TOKENS=600
GAP_ANALYSIS_REASONING_EFFORT=
CHAIN_RESOLVE_TEMPERATURE=0
CHAIN_RESOLVE_MAX_TOKENS=2000
CHAIN_RESOLVE_REASONING_EFFORT=
INPUT_RESOLVE_TEMPERATURE=0
INPUT_RESOLVE_MAX_TOKENS=2000
INPUT_RESOLVE_REASONING_EFFORT=
FIX_INPUTS_TEMPERATURE=0
FIX_INPUTS_MAX_TOKENS=1024
FIX_INPUTS_REASONING_EFFORT=low
UPSTREAM_RESOLVE_TEMPERATURE=0
UPSTREAM_RESOLVE_MAX_TOKENS=2000
UPSTREAM_RESOLVE_REASONING_EFFORT=
COMPOSE_TEMPERATURE=0.15
COMPOSE_MAX_TOKENS=8000
COMPOSE_REASONING_EFFORT=low

# Feature flags
AGENTIC_SEARCH_ENABLED=true
RECURSIVE_RETRIEVAL_ENABLED=false
EMBEDDINGS_ENABLED=false
MAX_RETRIEVAL_ITERS=3
TOP_K_CLAUSES=6

# Supabase (for auth & chat persistence — leave blank to run without auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
# Service role key (required for chat sync; get from Supabase Dashboard > Settings > API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
